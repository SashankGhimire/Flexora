{
  "name": "flexora-backend",
  "version": "1.0.0",
  "description": "Authentication backend for Flexora - Final Year Project",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "ngrok": "ngrok http 5000 --pooling-enabled",
    "ngrok:sync": "node scripts/sync-ngrok-url.js",
    "ngrok:auto": "node scripts/sync-ngrok-url.js --watch",
    "dev:tunnel": "concurrently -k \"npm:dev\" \"npm:ngrok\" \"npm:ngrok:auto\""
  },
  "keywords": [
    "authentication",
    "mern",
    "flexora"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^7.8.9",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "ngrok": "^5.0.0-beta.2",
    "nodemon": "^3.1.11"
  },
  "type": "commonjs"
}
